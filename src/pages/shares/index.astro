---
import { getCollection } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDateTime } from "../../lib/format";

const shares = (await getCollection("shares")).sort(
  (left, right) => right.data.sharedAt.getTime() - left.data.sharedAt.getTime()
);
---

<BaseLayout
  title="Shares | Agentic Builders Collective"
  description="A chronological log of what the collective has shared."
>
  <section class="panel">
    <div class="section-heading">
      <div>
        <h1 class="page-title">Shares</h1>
      </div>
    </div>
  </section>

  {
    shares.length > 0 ? (
      <section class="list">
        {shares.map((share) => (
          <article class="list-item">
            <div class="list-item-header">
              <strong class="list-item-title">{share.data.title}</strong>
              <div class="card-meta">
                <span>{formatDateTime(share.data.sharedAt)}</span>
                {share.data.sharedBy && <span>Shared by {share.data.sharedBy}</span>}
                {share.data.channel && <span>{share.data.channel}</span>}
              </div>
            </div>

            {share.data.note && <p>{share.data.note}</p>}

            {share.data.resourceUrl && (
              <p>
                <a class="muted-link" href={share.data.resourceUrl} target="_blank" rel="noreferrer">
                  Open shared item
                </a>
              </p>
            )}

            {share.data.tags.length > 0 && (
              <ul class="tag-list" aria-label={`Tags for ${share.data.title}`}>
                {share.data.tags.map((tag) => (
                  <li class="tag">{tag}</li>
                ))}
              </ul>
            )}
          </article>
        ))}
      </section>
    ) : (
      <section class="empty-state">
        <p>Nothing here yet.</p>
      </section>
    )
  }
</BaseLayout>
