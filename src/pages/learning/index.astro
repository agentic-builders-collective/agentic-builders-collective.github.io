---
import { getCollection } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";

const items = (await getCollection("learning")).sort(
  (left, right) =>
    (right.data.updated?.getTime() ?? 0) - (left.data.updated?.getTime() ?? 0)
);
---

<BaseLayout
  title="Learning | Agentic Builders Collective"
  description="Courses, guides, and learning resources curated by the collective."
>
  <h1 class="page-title">Learning</h1>

  {
    items.length > 0 ? (
      <section class="list">
        {items.map((item) => (
          <article class="list-item">
            <div class="list-item-header">
              <a class="list-item-title" href={item.data.link} target="_blank" rel="noreferrer">
                {item.data.title}
              </a>
              <div class="card-meta">
                {item.data.platform && <span>{item.data.platform}</span>}
                {item.data.by && <span>by {item.data.by}</span>}
              </div>
            </div>

            {item.data.tags.length > 0 && (
              <ul class="tag-list" aria-label={`Tags for ${item.data.title}`}>
                {item.data.tags.map((tag) => (
                  <li class="tag">{tag}</li>
                ))}
              </ul>
            )}
          </article>
        ))}
      </section>
    ) : (
      <section class="empty-state">
        <p>Nothing here yet.</p>
      </section>
    )
  }
</BaseLayout>
