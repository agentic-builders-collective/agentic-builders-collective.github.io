---
import { getCollection } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";

const resources = (await getCollection("resources")).sort((left, right) =>
  left.data.title.localeCompare(right.data.title)
);
---

<BaseLayout
  title="Resources | Agentic Builders Collective"
  description="Links, repositories, guides, and references shared by the collective."
>
  <section class="panel">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Shared references</p>
        <h1>Resources</h1>
        <p>
          Use YAML here for anything that behaves like a structured link: guides, tools,
          repositories, videos, or event references.
        </p>
      </div>
    </div>
  </section>

  {
    resources.length > 0 ? (
      <section class="list">
        {resources.map((resource) => (
          <article class="list-item">
            <div class="list-item-header">
              <a class="list-item-title" href={resource.data.url} target="_blank" rel="noreferrer">
                {resource.data.title}
              </a>
              <div class="card-meta">
                <span>{resource.data.kind}</span>
                {resource.data.addedBy && <span>Added by {resource.data.addedBy}</span>}
                {resource.data.featured && <span>Featured</span>}
              </div>
            </div>

            {resource.data.summary && <p>{resource.data.summary}</p>}

            {resource.data.tags.length > 0 && (
              <ul class="tag-list" aria-label={`Tags for ${resource.data.title}`}>
                {resource.data.tags.map((tag) => (
                  <li class="tag">{tag}</li>
                ))}
              </ul>
            )}
          </article>
        ))}
      </section>
    ) : (
      <section class="empty-state">
        <p>
          No resources are listed yet. Add one YAML file per item under <code>src/data/resources/</code>.
        </p>
      </section>
    )
  }
</BaseLayout>
