---
import BaseLayout from "../../layouts/BaseLayout.astro";
import QRCode from "../../components/QRCode.astro";
import { getCollection } from "astro:content";

const allEvents = await getCollection("events");
const now = new Date();
const formatTime = (time: string) => time.replace(/\s*SGT$/, "");

const upcoming = allEvents
  .filter((e) => e.data.status === "upcoming" || new Date(e.data.date) >= now)
  .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime());

const past = allEvents
  .filter((e) => e.data.status === "past" && new Date(e.data.date) < now)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const pastMeetups = past.filter((event) => event.data.kind !== "learning");
const pastLearning = past.filter((event) => event.data.kind === "learning");
---

<BaseLayout title="Events — ABC">
  <style>
    .events-muted-link::after {
      content: none;
    }

    .events-register {
      justify-self: start;
    }

    .survey-section {
      margin-top: 16px;
      padding: 16px;
      background: var(--box-bg, rgba(30, 30, 40, 0.45));
      border-radius: 12px;
      border: 1px solid var(--line, rgba(255, 255, 255, 0.08));
    }

    .survey-title {
      font-weight: 600;
      color: var(--accent);
      margin-bottom: 8px;
    }

    .survey-link {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      color: var(--accent);
      text-decoration: underline;
      font-weight: 500;
    }

    .survey-link:hover {
      color: var(--text);
      text-decoration: none;
    }

    .feedback-section {
      margin-top: 16px;
      padding: 16px;
      background: var(--box-bg, rgba(30, 30, 40, 0.45));
      border-radius: 12px;
      border: 1px solid var(--line, rgba(255, 255, 255, 0.08));
    }

    .feedback-rating {
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--accent);
      margin-bottom: 8px;
    }

    .feedback-highlight {
      padding: 8px 0;
      border-bottom: 1px solid var(--line, rgba(255, 255, 255, 0.08));
    }

    .feedback-highlight:last-child {
      border-bottom: none;
    }

    .qr-section {
      margin-top: 16px;
      text-align: center;
    }

    .qr-label {
      font-size: 0.875rem;
      color: var(--muted);
      margin-top: 12px;
    }
  </style>

  <h1 class="page-title">Events</h1>

  <section>
    <h3 class="section-label">Upcoming</h3>
    {upcoming.length === 0 ? (
      <div class="card">
        <p>No upcoming events — <a href="https://chat.whatsapp.com/Be8X9lVJQET4JfkKMW5Qxn" target="_blank" rel="noopener" style="color:var(--accent);">join the WhatsApp chat</a> for announcements.</p>
      </div>
    ) : (
      <div class="list">
        {upcoming.map((event) => (
          <div class="list-item" id={event.id}>
            <div class="list-item-header">
              {event.data.registrationUrl ? (
                <a class="list-item-title" href={event.data.registrationUrl} target="_blank" rel="noopener">{event.data.title}</a>
              ) : (
                <span class="list-item-title">{event.data.title}</span>
              )}
              <div class="card-meta">
                <span>{new Date(event.data.date).toLocaleDateString("en-SG", { weekday: "short", year: "numeric", month: "short", day: "numeric" })}</span>
                {event.data.time && <span>{formatTime(event.data.time)}</span>}
                {event.data.sponsorName && (
                  <span>
                    sponsored by{" "}
                    {event.data.sponsorUrl ? (
                      <a class="muted-link events-muted-link" href={event.data.sponsorUrl} target="_blank" rel="noopener">{event.data.sponsorName}</a>
                    ) : (
                      event.data.sponsorName
                    )}
                  </span>
                )}
              </div>
            </div>
            {event.data.registrationUrl && (
              <a class="button button-primary events-register" href={event.data.registrationUrl} target="_blank" rel="noopener">Register <span class="inline-arrow" aria-hidden="true">▶</span></a>
            )}
            
            {/* Pre-event survey */}
            {event.data.preEventSurvey?.url && (
              <div class="survey-section">
                <div class="survey-title">📋 Help shape this event</div>
                <a class="survey-link" href={event.data.preEventSurvey.url} target="_blank" rel="noopener">
                  Share topic suggestions →
                </a>
                {event.data.preEventSurvey.closesAt && (
                  <div style="font-size: 0.875rem; color: var(--muted); margin-top: 4px;">
                    Closes {new Date(event.data.preEventSurvey.closesAt).toLocaleDateString("en-SG", { month: "short", day: "numeric" })}
                  </div>
                )}
              </div>
            )}
          </div>
        ))}
      </div>
    )}
  </section>

  <section>
    <h3 class="section-label">Meetups</h3>
    {pastMeetups.length === 0 ? (
      <p>No past events yet.</p>
    ) : (
      <div class="list">
        {pastMeetups.map((event) => (
          <div class="list-item" id={event.id}>
            <div class="list-item-header">
              {event.data.registrationUrl ? (
                <a class="list-item-title" href={event.data.registrationUrl} target="_blank" rel="noopener">{event.data.title}</a>
              ) : (
                <span class="list-item-title">{event.data.title}</span>
              )}
              <div class="card-meta">
                <span>{new Date(event.data.date).toLocaleDateString("en-SG", { year: "numeric", month: "short", day: "numeric" })}</span>
                {event.data.time && <span>{formatTime(event.data.time)}</span>}
                {event.data.sponsorName && (
                  <span>
                    sponsored by{" "}
                    {event.data.sponsorUrl ? (
                      <a class="muted-link events-muted-link" href={event.data.sponsorUrl} target="_blank" rel="noopener">{event.data.sponsorName}</a>
                    ) : (
                      event.data.sponsorName
                    )}
                  </span>
                )}
              </div>
            </div>
            
            {/* Post-event survey with QR */}
            {event.data.postEventSurvey?.url && event.data.postEventSurvey?.qrEnabled && (
              <div class="survey-section">
                <div class="survey-title">📱 Share your feedback</div>
                <div class="qr-section">
                  <QRCode url={event.data.postEventSurvey.url} size={150} />
                  <div class="qr-label">Scan to rate this event</div>
                </div>
                <a class="survey-link" href={event.data.postEventSurvey.url} target="_blank" rel="noopener" style="margin-top: 12px;">
                  Open survey →
                </a>
              </div>
            )}
            
            {/* Feedback results */}
            {event.data.feedback && (
              <div class="feedback-section">
                <div class="feedback-rating">
                  ★ {event.data.feedback.rating.toFixed(1)} 
                  <span style="font-size: 0.875rem; font-weight: 400; color: var(--muted);">
                    ({event.data.feedback.responses} responses)
                  </span>
                </div>
                {event.data.feedback.highlights && event.data.feedback.highlights.length > 0 && (
                  <div>
                    {event.data.feedback.highlights.map((highlight) => (
                      <div class="feedback-highlight">"{highlight}"</div>
                    ))}
                  </div>
                )}
              </div>
            )}
          </div>
        ))}
      </div>
    )}
  </section>

  <section>
    <h3 class="section-label">Learning</h3>
    {pastLearning.length === 0 ? (
      <p>No learning sessions yet.</p>
    ) : (
      <div class="list">
        {pastLearning.map((event) => (
          <div class="list-item" id={event.id}>
            <div class="list-item-header">
              {event.data.registrationUrl ? (
                <a class="list-item-title" href={event.data.registrationUrl} target="_blank" rel="noopener">{event.data.title}</a>
              ) : (
                <span class="list-item-title">{event.data.title}</span>
              )}
              <div class="card-meta">
                <span>{new Date(event.data.date).toLocaleDateString("en-SG", { year: "numeric", month: "short", day: "numeric" })}</span>
                {event.data.time && <span>{formatTime(event.data.time)}</span>}
                {event.data.sponsorName && (
                  <span>
                    sponsored by{" "}
                    {event.data.sponsorUrl ? (
                      <a class="muted-link events-muted-link" href={event.data.sponsorUrl} target="_blank" rel="noopener">{event.data.sponsorName}</a>
                    ) : (
                      event.data.sponsorName
                    )}
                  </span>
                )}
              </div>
            </div>
            
            {/* Post-event survey with QR */}
            {event.data.postEventSurvey?.url && event.data.postEventSurvey?.qrEnabled && (
              <div class="survey-section">
                <div class="survey-title">📱 Share your feedback</div>
                <div class="qr-section">
                  <QRCode url={event.data.postEventSurvey.url} size={150} />
                  <div class="qr-label">Scan to rate this event</div>
                </div>
                <a class="survey-link" href={event.data.postEventSurvey.url} target="_blank" rel="noopener" style="margin-top: 12px;">
                  Open survey →
                </a>
              </div>
            )}
            
            {/* Feedback results */}
            {event.data.feedback && (
              <div class="feedback-section">
                <div class="feedback-rating">
                  ★ {event.data.feedback.rating.toFixed(1)} 
                  <span style="font-size: 0.875rem; font-weight: 400; color: var(--muted);">
                    ({event.data.feedback.responses} responses)
                  </span>
                </div>
                {event.data.feedback.highlights && event.data.feedback.highlights.length > 0 && (
                  <div>
                    {event.data.feedback.highlights.map((highlight) => (
                      <div class="feedback-highlight">"{highlight}"</div>
                    ))}
                  </div>
                )}
              </div>
            )}
          </div>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
