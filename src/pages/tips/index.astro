---
import { getCollection } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/format";

const tips = (await getCollection("tips", ({ data }) => !data.draft)).sort(
  (left, right) =>
    (right.data.publishedAt?.getTime() ?? 0) - (left.data.publishedAt?.getTime() ?? 0)
);
---

<BaseLayout
  title="Tips | Agentic Builders Collective"
  description="Markdown guides, notes, and working tips from the collective."
>
  <section class="panel">
    <div class="section-heading">
      <div>
        <h1 class="page-title">Tips</h1>
      </div>
    </div>
  </section>

  {
    tips.length > 0 ? (
      <section class="list">
        {tips.map((tip) => (
          <article class="list-item">
            <div class="list-item-header">
              <a class="list-item-title" href={`/tips/${tip.id}/`}>
                {tip.data.title}
              </a>
              <div class="card-meta">
                {tip.data.publishedAt && <span>{formatDate(tip.data.publishedAt)}</span>}
                <span>{tip.id}</span>
              </div>
            </div>

            {tip.data.summary && <p>{tip.data.summary}</p>}

            {tip.data.tags.length > 0 && (
              <ul class="tag-list" aria-label={`Tags for ${tip.data.title}`}>
                {tip.data.tags.map((tag) => (
                  <li class="tag">{tag}</li>
                ))}
              </ul>
            )}
          </article>
        ))}
      </section>
    ) : (
      <section class="empty-state">
        <p>Nothing here yet.</p>
      </section>
    )
  }
</BaseLayout>
