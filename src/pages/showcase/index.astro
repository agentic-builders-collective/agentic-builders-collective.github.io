---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const allProjects = await getCollection("projects");
const allPresentations = await getCollection("presentations");

const projects = allProjects.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const presentations = allPresentations.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout
  title="showcase"
  description="Browse projects, demos, and member-built work from the Agentic Builders Collective community."
>
  <h1 class="page-title">Showcase</h1>

  <section>
    <h3 class="section-label">Projects</h3>
    {projects.length > 0 ? (
      <div class="list">
        {projects.map((project) => (
          <article class="list-item">
            {project.data.screenshot && (
              <img
                src={project.data.screenshot}
                alt={project.data.title}
                loading="lazy"
                decoding="async"
                width="800"
                height="450"
                class="showcase-image"
              />
            )}
            <div class="list-item-header">
              <span class="list-item-title">
                {project.data.url ? (
                  <a href={project.data.url} target="_blank" rel="noopener">{project.data.title}</a>
                ) : (
                  project.data.title
                )}
              </span>
              <div class="card-meta">
                {project.data.author && <span>{project.data.author}</span>}
                <span>{new Date(project.data.date).toLocaleDateString("en-SG", { year: "numeric", month: "short" })}</span>
              </div>
            </div>
            {project.data.summary && <p>{project.data.summary}</p>}
            <div style="display:flex;gap:12px;flex-wrap:wrap;">
              {project.data.url && (
                <a class="muted-link" href={project.data.url} target="_blank" rel="noopener">Live site</a>
              )}
              {project.data.github && (
                <a class="muted-link" href={project.data.github} target="_blank" rel="noopener">GitHub</a>
              )}
            </div>
            {project.data.builtWith.length > 0 && (
              <ul class="tag-list">
                {project.data.builtWith.map((tool) => (
                  <li class="tag">{tool}</li>
                ))}
              </ul>
            )}
          </article>
        ))}
      </div>
    ) : (
      <p>No projects yet. Submit yours via PR!</p>
    )}
  </section>

  <section>
    <h3 class="section-label">Presentations</h3>
    {presentations.length > 0 ? (
      <div class="list">
        {presentations.map((presentation) => (
          <article class="list-item" id={presentation.data.id}>
            <div class="list-item-header">
              <span class="list-item-title">
                {presentation.data.url ? (
                  <a href={presentation.data.url} target="_blank" rel="noopener">{presentation.data.title}</a>
                ) : (
                  presentation.data.title
                )}
              </span>
              <div class="card-meta">
                {presentation.data.speaker && <span>{presentation.data.speaker}</span>}
                {presentation.data.event && <span>{presentation.data.event}</span>}
                <span>{new Date(presentation.data.date).toLocaleDateString("en-SG", { year: "numeric", month: "short" })}</span>
              </div>
            </div>
            {presentation.data.summary && <p>{presentation.data.summary}</p>}
            <div style="display:flex;gap:12px;flex-wrap:wrap;">
              {presentation.data.url && (
                <a class="muted-link" href={presentation.data.url} target="_blank" rel="noopener">Page</a>
              )}
              {presentation.data.slidesUrl && (
                <a class="muted-link" href={presentation.data.slidesUrl} target="_blank" rel="noopener">Slides</a>
              )}
              {presentation.data.videoUrl && (
                <a class="muted-link" href={presentation.data.videoUrl} target="_blank" rel="noopener">Video</a>
              )}
            </div>
            {presentation.data.tags.length > 0 && (
              <ul class="tag-list">
                {presentation.data.tags.map((tag) => (
                  <li class="tag">{tag}</li>
                ))}
              </ul>
            )}
          </article>
        ))}
      </div>
    ) : (
      <p>No presentations yet.</p>
    )}
  </section>
</BaseLayout>

<style>
  .showcase-image {
    aspect-ratio: 16 / 9;
    border: 1px solid var(--line);
    display: block;
    object-fit: cover;
    width: 100%;
  }
</style>
