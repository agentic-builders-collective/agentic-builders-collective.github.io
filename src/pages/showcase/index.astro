---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import TerminalNoteLink from "../../components/TerminalNoteLink.astro";
import { contributionLinks } from "../../lib/contribution-links";
import { buildEventIndex, buildPeopleIndex, getLinkedEvent, resolvePersonRefs } from "../../lib/relations";

const allProjects = await getCollection("projects");
const allPresentations = await getCollection("presentations");
const allArticles = await getCollection("articles");
const allEvents = await getCollection("events");
const allMembers = await getCollection("members");
const organisers = await getCollection("organisers");
const peopleById = buildPeopleIndex([...organisers, ...allMembers]);
const eventsById = buildEventIndex(allEvents);

const projects = allProjects.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const articles = allArticles.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

type PresentationEntry = (typeof allPresentations)[number];

const presentationsByEvent = new Map<string, { event: ReturnType<typeof getLinkedEvent>; presentations: PresentationEntry[] }>();
for (const presentation of allPresentations) {
  const event = getLinkedEvent(presentation.data.eventId, eventsById, `presentation "${presentation.data.id}"`);
  const bucket = presentationsByEvent.get(event.id);
  if (bucket) {
    bucket.presentations.push(presentation);
  } else {
    presentationsByEvent.set(event.id, { event, presentations: [presentation] });
  }
}

const eventGroups = Array.from(presentationsByEvent.values()).sort(
  (a, b) => new Date(b.event.data.date).getTime() - new Date(a.event.data.date).getTime()
);
---

<BaseLayout
  title="showcase"
  description="Browse presentations, projects, articles, demos, and member-built work from the Agentic Builders Collective community."
>
  <h1 class="page-title showcase-title">
    <span class="showcase-title-label">Showcase</span><span class="showcase-title-colon">:</span>
    <span class="showcase-section-nav" role="navigation" aria-label="Showcase sections">
      <a href="#presentations">Presentations</a>
      <span class="showcase-section-separator" aria-hidden="true">/</span>
      <a href="#projects">Projects</a>
      <span class="showcase-section-separator" aria-hidden="true">/</span>
      <a href="#articles">Articles</a>
    </span>
  </h1>

  <details class="showcase-section" id="presentations" open>
    <summary class="section-label collapsible-heading">Presentations</summary>
    <div class="showcase-section-body">
      <p class="collection-guide">
        Presentations from our meetups will go here.
      </p>
    {eventGroups.length > 0 ? (
      <div class="event-groups">
        {eventGroups.map(({ event, presentations }) => (
          <details class="event-group" open>
            <summary class="event-group-header">
              <span class="event-group-title">
                {event.data.title.replace(/^#\d+\s*[-–—]\s*/, "")}
              </span>
              <span class="event-group-date">
                {new Date(event.data.date).toLocaleDateString("en-SG", { year: "numeric", month: "short", day: "numeric" })}
              </span>
            </summary>
            <div class="list presentation-list">
              {presentations.map((presentation) => {
                const speakers = resolvePersonRefs(
                  presentation.data.speakers,
                  peopleById,
                  `presentation "${presentation.data.id}" speakers`,
                );
                return (
                  <article class="list-item presentation-card" id={presentation.data.id}>
                    {speakers.length > 0 && (
                      <span class="presentation-speaker">
                        {speakers.map((speaker, index) => (
                          <>
                            {speaker.href ? (
                              <a href={speaker.href}>{speaker.name}</a>
                            ) : (
                              speaker.name
                            )}
                            {index < speakers.length - 1 && ", "}
                          </>
                        ))}
                      </span>
                    )}
                    {presentation.data.screenshot && (() => {
                      const slideHref = presentation.data.slidesUrl || presentation.data.url || "";
                      const img = (
                        <img
                          src={presentation.data.screenshot}
                          alt={`${presentation.data.title} — first slide`}
                          loading="lazy"
                          decoding="async"
                          width="800"
                          height="450"
                          class="showcase-image"
                        />
                      );
                      return slideHref ? (
                        <a class="showcase-image-link" href={slideHref} target="_blank" rel="noopener" aria-label={`${presentation.data.title} — open slides`}>
                          {img}
                        </a>
                      ) : img;
                    })()}
                    <span class="presentation-title">
                      {presentation.data.url ? (
                        <a href={presentation.data.url} target="_blank" rel="noopener">{presentation.data.title}</a>
                      ) : (
                        presentation.data.title
                      )}
                    </span>
                    <div class="presentation-summary-block">
                      {presentation.data.summary && <p class="presentation-summary">{presentation.data.summary}</p>}
                      {presentation.data.noteTeaser && <p class="presentation-note-teaser">{presentation.data.noteTeaser}</p>}
                    </div>
                    <div class="presentation-links-block">
                      <span class="presentation-links-label">Links</span>
                      <div class="presentation-links">
                        {presentation.data.slidesUrl && (
                          <a class="muted-link" href={presentation.data.slidesUrl} target="_blank" rel="noopener">Slides</a>
                        )}
                        {presentation.data.videoUrl && (
                          <a class="muted-link" href={presentation.data.videoUrl} target="_blank" rel="noopener">Video</a>
                        )}
                        {presentation.data.url && presentation.data.url !== presentation.data.slidesUrl && (
                          <a class="muted-link" href={presentation.data.url} target="_blank" rel="noopener">Page</a>
                        )}
                        {presentation.data.links.map((link) => (
                          <TerminalNoteLink href={link.url} label={link.label} note={link.note} />
                        ))}
                      </div>
                    </div>
                  </article>
                );
              })}
            </div>
          </details>
        ))}
      </div>
    ) : (
      <p>No presentations yet. <a class="muted-link" href={contributionLinks.presentation} target="_blank" rel="noopener">Add slides by submitting a pull request</a></p>
    )}
    </div>
  </details>

  <details class="showcase-section" id="projects" open>
    <summary class="section-label collapsible-heading">Projects</summary>
    <div class="showcase-section-body">
      <p class="collection-guide">
        Want to add something? Follow the <a class="muted-link" href={contributionLinks.project} target="_blank" rel="noopener">contribution guide</a>
      </p>
    {projects.length > 0 ? (
      <div class="list">
        {projects.map((project) => (
          <article class="list-item" id={project.id}>
            {project.data.screenshot && (
              <img
                src={project.data.screenshot}
                alt={project.data.title}
                loading="lazy"
                decoding="async"
                width="800"
                height="450"
                class="showcase-image"
              />
            )}
            <div class="list-item-header">
              <span class="list-item-title">
                {project.data.url ? (
                  <a href={project.data.url} target="_blank" rel="noopener">{project.data.title}</a>
                ) : (
                  project.data.title
                )}
              </span>
              <div class="card-meta">
                {(() => {
                  const makers = resolvePersonRefs(project.data.makers, peopleById, `project "${project.id}" makers`);
                  return makers.length > 0 && (
                    <span>
                      {makers.map((maker, index) => (
                        <>
                          {maker.href ? (
                            <a href={maker.href}>{maker.name}</a>
                          ) : (
                            maker.name
                          )}
                          {index < makers.length - 1 && ", "}
                        </>
                      ))}
                    </span>
                  );
                })()}
                <span>{new Date(project.data.date).toLocaleDateString("en-SG", { year: "numeric", month: "short" })}</span>
              </div>
            </div>
            {project.data.summary && <p>{project.data.summary}</p>}
            <div style="display:flex;gap:12px;flex-wrap:wrap;">
              {project.data.url && (
                <a class="muted-link" href={project.data.url} target="_blank" rel="noopener">Live site</a>
              )}
              {project.data.github && (
                <a class="muted-link" href={project.data.github} target="_blank" rel="noopener">GitHub</a>
              )}
            </div>
            {project.data.builtWith.length > 0 && (
              <ul class="tag-list">
                {project.data.builtWith.map((tool) => (
                  <li class="tag">{tool}</li>
                ))}
              </ul>
            )}
          </article>
        ))}
      </div>
    ) : (
      <p>No projects yet. <a class="muted-link" href={contributionLinks.project} target="_blank" rel="noopener">Add a project by submitting a pull request</a></p>
    )}
    </div>
  </details>

  <details class="showcase-section" id="articles" open>
    <summary class="section-label collapsible-heading">Articles</summary>
    <div class="showcase-section-body">
      <p class="collection-guide">
        Want to add something? Follow the <a class="muted-link" href={contributionLinks.article} target="_blank" rel="noopener">contribution guide</a>
      </p>
      {articles.length > 0 ? (
        <div class="list">
          {articles.map((article) => (
            <article class="list-item" id={article.data.id}>
              <div class="list-item-header">
                <a class="list-item-title" href={article.data.url} target="_blank" rel="noopener">
                  {article.data.title}
                </a>
                <div class="card-meta">
                  {(() => {
                    const authors = resolvePersonRefs(article.data.authors, peopleById, `article "${article.data.id}" authors`);
                    return authors.length > 0 && (
                      <span>
                        {authors.map((author, index) => (
                          <>
                            {author.href ? (
                              <a href={author.href}>{author.name}</a>
                            ) : (
                              author.name
                            )}
                            {index < authors.length - 1 && ", "}
                          </>
                        ))}
                      </span>
                    );
                  })()}
                  {article.data.publication && <span>{article.data.publication}</span>}
                  <span>{new Date(article.data.date).toLocaleDateString("en-SG", { year: "numeric", month: "short" })}</span>
                </div>
              </div>
              {article.data.summary && <p>{article.data.summary}</p>}
              {article.data.tags.length > 0 && (
                <ul class="tag-list">
                  {article.data.tags.map((tag) => (
                    <li class="tag">{tag}</li>
                  ))}
                </ul>
              )}
            </article>
          ))}
        </div>
      ) : (
        <p>No articles yet. <a class="muted-link" href={contributionLinks.article} target="_blank" rel="noopener">Add an article by submitting a pull request</a></p>
      )}
    </div>
  </details>
</BaseLayout>

<style>
  .showcase-title {
    align-items: center;
    display: flex;
    flex-wrap: nowrap;
    overflow-x: auto;
  }

  .showcase-title::before {
    flex: 0 0 auto;
  }

  .showcase-section-nav {
    align-items: center;
    color: var(--logo-gradient-end);
    display: inline-flex;
    flex-wrap: nowrap;
    gap: 8px;
    margin-left: 8px;
    white-space: nowrap;
  }

  .showcase-title-label {
    color: var(--logo-gradient-start);
  }

  .showcase-title-colon {
    color: #555;
  }

  .showcase-section-nav a {
    color: var(--logo-gradient-end);
    text-decoration: none;
  }

  .showcase-section-separator {
    color: #555;
  }

  .showcase-section-nav a:hover,
  .showcase-section-nav a:focus-visible {
    text-decoration: underline;
  }

  .showcase-section {
    display: block;
  }

  .showcase-section-body {
    display: grid;
    gap: 0;
  }

  .collapsible-heading,
  .event-group-header {
    cursor: pointer;
    list-style: none;
  }

  .collapsible-heading {
    align-items: center;
    display: flex;
    justify-content: space-between;
    width: 100%;
  }

  .collapsible-heading::-webkit-details-marker,
  .event-group-header::-webkit-details-marker {
    display: none;
  }

  .collapsible-heading::after,
  .event-group-header::after {
    color: #555;
    content: "[+]";
    margin-left: auto;
  }

  .showcase-section[open] > .collapsible-heading::after,
  .event-group[open] > .event-group-header::after {
    content: "[-]";
  }

  .showcase-image {
    aspect-ratio: 16 / 9;
    border: 1px solid var(--line);
    display: block;
    object-fit: cover;
    width: 100%;
  }

  .presentation-card .showcase-image {
    align-self: start;
    aspect-ratio: 16 / 9;
    background: #0a0a0a;
    display: block;
    height: auto;
    justify-self: stretch;
    max-width: 100%;
    object-fit: contain;
    width: 100%;
  }

  .event-groups {
    display: grid;
    gap: 40px;
  }

  .event-group {
    display: grid;
    gap: 16px;
  }

  .event-group .presentation-list {
    display: grid;
    gap: 12px 20px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    grid-auto-rows: auto;
  }

  .presentation-card {
    display: grid;
    gap: 12px;
    grid-row: span 5;
    grid-template-rows: subgrid;
    padding: 14px 16px;
  }

  .presentation-summary-block {
    display: flex;
    flex-direction: column;
    gap: 0.6em;
  }

  .presentation-summary-block p {
    margin: 0;
  }

  @media (max-width: 720px) {
    .event-group .presentation-list {
      grid-template-columns: 1fr;
    }

    .presentation-card {
      grid-row: auto;
      grid-template-rows: auto;
    }
  }

  .showcase-image-link {
    align-self: start;
    display: block;
    justify-self: stretch;
    width: 100%;
  }

  .showcase-image-link .showcase-image {
    display: block;
    width: 100%;
  }

  .presentation-note-teaser {
    color: var(--muted);
  }

  .presentation-note-teaser:empty {
    display: block;
    min-height: 0;
  }

  .event-group-header {
    align-items: baseline;
    border-bottom: 1px solid var(--line);
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto auto;
    gap: 12px;
    padding-bottom: 8px;
  }

  .event-group-title {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 700;
    margin: 0;
  }

  .event-group-date {
    color: var(--muted);
    justify-self: end;
  }

  .presentation-speaker {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .presentation-speaker a {
    color: inherit;
    text-decoration: none;
  }

  .presentation-speaker a:hover,
  .presentation-speaker a:focus-visible {
    color: var(--accent);
  }

  .presentation-title {
    color: var(--muted);
    font-family: var(--font-serif);
    font-size: 1rem;
    font-style: italic;
    font-weight: 500;
    line-height: 1.35;
  }

  .presentation-title a {
    color: inherit;
    text-decoration: none;
  }

  .presentation-title a:hover,
  .presentation-title a:focus-visible {
    color: var(--accent);
  }

  .presentation-links-block {
    align-self: start;
    display: grid;
    gap: 6px;
  }

  .presentation-links-label {
    color: var(--muted);
    font-family: var(--font-serif);
    font-size: 1rem;
    font-style: italic;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .presentation-links {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 18px;
  }
</style>
