---
import { getCollection } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";

const people = (await getCollection("people")).sort((left, right) =>
  left.data.name.localeCompare(right.data.name)
);
---

<BaseLayout
  title="People | Agentic Builders Collective"
  description="Profiles of builders in the Agentic Builders Collective."
>
  <section class="panel">
    <div class="section-heading">
      <div>
        <h1 class="page-title">People</h1>
      </div>
    </div>
  </section>

  {
    people.length > 0 ? (
      <section class="grid columns-2">
        {people.map((person) => (
          <article class="card">
            <div class="card-header">
              <h3>{person.data.name}</h3>
            </div>

            {person.data.interests.length > 0 && (
              <ul class="tag-list" aria-label={`Interests for ${person.data.name}`}>
                {person.data.interests.map((interest) => (
                  <li class="tag">{interest}</li>
                ))}
              </ul>
            )}

            {person.data.notes && <p>{person.data.notes}</p>}

            <ul class="link-list" aria-label={`Links for ${person.data.name}`}>
              {person.data.linkedin && (
                <li>
                  <a class="muted-link" href={person.data.linkedin} target="_blank" rel="noreferrer">
                    linkedin
                  </a>
                </li>
              )}
              {person.data.website && (
                <li>
                  <a class="muted-link" href={person.data.website} target="_blank" rel="noreferrer">
                    website
                  </a>
                </li>
              )}
            </ul>
          </article>
        ))}
      </section>
    ) : (
      <section class="empty-state">
        <p>Nothing here yet.</p>
      </section>
    )
  }
</BaseLayout>
