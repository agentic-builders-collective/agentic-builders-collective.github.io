---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allMembers = await getCollection("members");
const organisers = await getCollection("organisers");

const orgNames = new Set(organisers.map((o) => o.data.name));
const members = allMembers
  .filter((person) => !orgNames.has(person.data.name))
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) {
      return a.data.featured ? -1 : 1;
    }

    return a.data.name.localeCompare(b.data.name);
  });
---

<BaseLayout
  title="community"
  description="Meet the organisers behind Agentic Builders Collective and explore the Singapore community building with AI coding tools."
>
  <h1 class="page-title">Community</h1>

  <section>
    <h3 class="section-label">Organisers</h3>
    <div class="grid columns-2">
      {organisers.map((person) => (
        <div class="person-card" id={person.data.id}>
          <div class="person-card-header">
            <span class="person-card-title">{person.data.name}</span>
            <div class="person-card-meta">
              <span>{person.data.role}</span>
              {person.data.company && (
                <span class="company-span">
                  {person.data.companyUrl ? (
                    <a href={person.data.companyUrl} target="_blank" rel="noopener" class="muted-link">{person.data.company}</a>
                  ) : (
                    person.data.company
                  )}
                </span>
              )}
            </div>
          </div>
          {person.data.tagline && <p class="person-card-tagline">{person.data.tagline}</p>}
          <div class="person-card-links">
            {person.data.website && (
              <a class="muted-link" href={person.data.website} target="_blank" rel="noopener">Website</a>
            )}
            {person.data.linkedin && (
              <a class="muted-link" href={person.data.linkedin} target="_blank" rel="noopener">LinkedIn</a>
            )}
            {person.data.github && (
              <a class="muted-link" href={person.data.github} target="_blank" rel="noopener">GitHub</a>
            )}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section>
    <h3 class="section-label">Members</h3>
    {members.length > 0 ? (
      <div class="grid columns-2">
        {members.map((person) => (
          <div class="person-card" id={person.data.id}>
            <div class="person-card-header">
              <span class="person-card-title">{person.data.name}</span>
              {(person.data.company || person.data.featured) && (
                <div class="person-card-meta">
                  {person.data.company && <span>{person.data.company}</span>}
                  {person.data.featured && <span>Featured</span>}
                </div>
              )}
            </div>
            {person.data.tagline && <p class="person-card-tagline">{person.data.tagline}</p>}
            <div class="person-card-links">
              {person.data.website && (
                <a class="muted-link" href={person.data.website} target="_blank" rel="noopener">Website</a>
              )}
              {person.data.linkedin && (
                <a class="muted-link" href={person.data.linkedin} target="_blank" rel="noopener">LinkedIn</a>
              )}
              {person.data.github && (
                <a class="muted-link" href={person.data.github} target="_blank" rel="noopener">GitHub</a>
              )}
            </div>
          </div>
        ))}
      </div>
    ) : (
      <p>No members listed yet.</p>
    )}
  </section>
</BaseLayout>
